{% extends 'base.html.twig' %}

{% block title %}Modifier ma Candidature - Cour Suprême du Bénin{% endblock %}

{% block stylesheets %}
	<link rel="stylesheet" href="{{ asset('css/style.css') }}">
    <style>
        .application-form-section {
            padding: 60px 0;
            background-color: #f8faff;
        }

        .form-card {
            background: white;
            border-radius: 15px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.05);
            padding: 40px;
            max-width: 900px;
            margin: 0 auto;
        }

        .form-header {
            text-align: center;
            margin-bottom: 40px;
            border-bottom: 2px solid #f0f0f0;
            padding-bottom: 20px;
        }

        .form-header h3 {
            color: #1a2b4b;
            font-size: 1.8rem;
            margin-bottom: 10px;
        }

        .form-section {
            margin-bottom: 40px;
        }

        .section-title {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 25px;
            color: var(--border-blue);
            font-size: 1.1rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .section-title span {
            background: var(--border-blue);
            color: white;
            width: 24px;
            height: 24px;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 50%;
            font-size: 0.8rem;
        }

        .grid-2 {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
        }

        .form-group {
            margin-bottom: 20px;
        }

        .form-group label {
            display: block;
            margin-bottom: 8px;
            font-weight: 600;
            color: #444;
            font-size: 0.9rem;
        }

        label[for]::after, .required-star {
            content: " *";
            color: #dc2626;
            font-weight: bold;
        }

        .form-control {
            width: 100%;
            padding: 10px 15px;
            border: 1.5px solid #e0e0e0;
            border-radius: 8px;
            font-size: 0.95rem;
            transition: border-color 0.3s;
        }

        .form-control:focus {
            outline: none;
            border-color: var(--border-blue);
        }

        .file-upload-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
            gap: 15px;
        }

        .file-upload-item {
            border: 2px dashed #e0e0e0;
            padding: 15px;
            border-radius: 10px;
            text-align: center;
            transition: all 0.3s;
            cursor: pointer;
            position: relative;
        }

        .file-upload-item:hover {
            border-color: var(--primary-green);
            background-color: #f0f7f4;
        }

        .file-input {
            display: none;
        }

        .btn-submit {
            background-color: var(--primary-green);
            color: white;
            border: none;
            padding: 15px 40px;
            border-radius: 8px;
            font-weight: 700;
            font-size: 1.1rem;
            cursor: pointer;
            width: 100%;
            margin-top: 20px;
            transition: all 0.3s;
        }

        .btn-submit:hover {
            background-color: var(--secondary-green);
            transform: translateY(-2px);
        }

        .btn-submit:disabled {
            background-color: #94a3b8;
            cursor: not-allowed;
            transform: none;
        }

        .spinner-loader {
            display: none;
            width: 20px;
            height: 20px;
            border: 3px solid rgba(255,255,255,.3);
            border-radius: 50%;
            border-top-color: #fff;
            animation: spin 1s ease-in-out infinite;
        }

        @keyframes spin {
            to { transform: rotate(360deg); }
        }

        .btn-content {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
        }

        .btn-cancel {
            display: block;
            text-align: center;
            margin-top: 15px;
            color: #666;
            text-decoration: none;
            font-weight: 600;
        }

        .invalid-feedback, .form-errors, .form-errors ul, .form-errors li {
            color: #dc2626 !important;
            font-size: 0.8rem;
            margin-top: 8px;
            list-style: none;
            padding: 0;
            font-weight: 600;
            text-align: center;
        }

        .file-upload-item.has-error {
            border-color: #dc2626 !important;
            background-color: #fef2f2;
            box-shadow: 0 0 0 4px rgba(220, 38, 38, 0.1);
        }

        .file-upload-item.has-error strong {
            color: #dc2626;
        }

        .is-invalid {
            border-color: #dc2626 !important;
        }

        .hp-field {
            display: none !important;
            visibility: hidden !important;
            opacity: 0 !important;
            position: absolute !important;
            top: -9999px !important;
            left: -9999px !important;
        }

        .global-error-alert {
            background-color: #fee2e2;
            border: 1px solid #fecdd3;
            color: #991b1b;
            padding: 15px;
            border-radius: 8px;
            margin-bottom: 30px;
            display: flex;
            align-items: center;
            gap: 12px;
            font-weight: 600;
        }

        @media (max-width: 768px) {
            .grid-2 {
                grid-template-columns: 1fr;
            }
        }
    </style>
{% endblock %}

{% block body %}
	<header>
		<div class="container">
			<div class="header-top">
				<div class="logo-section">
                    <a href="{{ path('app_home') }}">
					    <img src="{{ asset('images/logo_cour_supreme.jpeg') }}" alt="Logo Bénin">
                    </a>
				</div>
                <div class="nav-actions">
                    <a href="{{ path('app_suivi') }}" class="btn-outline">Retour au suivi</a>
                </div>
			</div>
		</div>
	</header>

	<main>
        <section class="application-form-section">
            <div class="container">
                <div class="form-card">
                    <div class="form-header">
                        <h3>Modifier ma Candidature</h3>
                        <p>Vous pouvez mettre à jour vos informations tant que votre dossier est en attente.</p>
                        <div style="margin-top: 10px; font-weight: bold; color: var(--border-blue);">
                            Référence : {{ dossier.reference }}
                        </div>
                    </div>

                    {% if not form.vars.valid %}
                        <div class="global-error-alert">
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="8" x2="12" y2="12"></line><line x1="12" y1="16" x2="12.01" y2="16"></line></svg>
                            <span>La modification a échoué. Veuillez vérifier les erreurs en rouge ci-dessous.</span>
                        </div>
                    {% endif %}

                    {{ form_start(form, {'attr': {'novalidate': 'novalidate', 'id': 'modifierForm', 'action': path('app_modifier_candidature'), 'method': 'POST'}}) }}
                        <!-- Section 1: Informations Personnelles -->
                        <div class="form-section">
                            <div class="section-title"><span>1</span> Informations Personnelles</div>
                            <div class="grid-2">
                                <div class="form-group" data-field="nom">
                                    {{ form_label(form.nom, 'Nom') }}
                                    {{ form_widget(form.nom, {'attr': {'class': 'form-control' ~ (form.nom.vars.valid ? '' : ' is-invalid')}}) }}
                                    <div class="form-errors">{{ form_errors(form.nom) }}</div>
                                </div>
                                <div class="form-group" data-field="prenom">
                                    {{ form_label(form.prenom, 'Prénom(s)') }}
                                    {{ form_widget(form.prenom, {'attr': {'class': 'form-control' ~ (form.prenom.vars.valid ? '' : ' is-invalid')}}) }}
                                    <div class="form-errors">{{ form_errors(form.prenom) }}</div>
                                </div>
                            </div>
                            <div class="grid-2">
                                <div class="form-group">
                                    {{ form_label(form.email, 'Adresse Email (non modifiable)') }}
                                    {{ form_widget(form.email, {'attr': {'class': 'form-control', 'style': 'background-color: #f0f0f0; cursor: not-allowed;', 'readonly': 'readonly'}}) }}
                                </div>
                                <div class="form-group" data-field="telephone">
                                    {{ form_label(form.telephone, 'Téléphone') }}
                                    {{ form_widget(form.telephone, {'attr': {'class': 'form-control' ~ (form.telephone.vars.valid ? '' : ' is-invalid')}}) }}
                                    <div class="form-errors">{{ form_errors(form.telephone) }}</div>
                                    <small class="helper-text">Doit commencer par 01.</small>
                                </div>
                            </div>
                            <div class="grid-2">
                                <div class="form-group" data-field="sexe">
                                    {{ form_label(form.sexe, 'Sexe') }}
                                    {{ form_widget(form.sexe, {'attr': {'class': 'form-control' ~ (form.sexe.vars.valid ? '' : ' is-invalid')}}) }}
                                    <div class="form-errors">{{ form_errors(form.sexe) }}</div>
                                </div>
                                <div class="form-group" data-field="dob">
                                    {{ form_label(form.dob, 'Date de naissance') }}
                                    {{ form_widget(form.dob, {'attr': {'class': 'form-control' ~ (form.dob.vars.valid ? '' : ' is-invalid')}}) }}
                                    <div class="form-errors">{{ form_errors(form.dob) }}</div>
                                </div>
                            </div>
                        </div>

                        <!-- Section 2: Cursus Académique -->
                        <div class="form-section">
                            <div class="section-title"><span>2</span> Cursus Académique</div>
                            <div class="form-group" data-field="etablissement">
                                {{ form_label(form.etablissement, 'Dernier Établissement Fréquenté') }}
                                {{ form_widget(form.etablissement, {'attr': {'class': 'form-control' ~ (form.etablissement.vars.valid ? '' : ' is-invalid')}}) }}
                                <div class="form-errors">{{ form_errors(form.etablissement) }}</div>
                            </div>
                            <div class="grid-2">
                                <div class="form-group" data-field="niveau">
                                    {{ form_label(form.niveau, 'Niveau d\'études actuel') }}
                                    {{ form_widget(form.niveau, {'attr': {'class': 'form-control' ~ (form.niveau.vars.valid ? '' : ' is-invalid')}}) }}
                                    <div class="form-errors">{{ form_errors(form.niveau) }}</div>
                                </div>
                                <div class="form-group" data-field="filiere">
                                    {{ form_label(form.filiere, 'Filière / Spécialité') }}
                                    {{ form_widget(form.filiere, {'attr': {'class': 'form-control' ~ (form.filiere.vars.valid ? '' : ' is-invalid')}}) }}
                                    <div class="form-errors">{{ form_errors(form.filiere) }}</div>
                                </div>
                            </div>
                        </div>

                        <!-- Section 3: Détails du Stage -->
                        <div class="form-section">
                            <div class="section-title"><span>3</span> Détails du Stage</div>
                            <div class="grid-2">
                                <div class="form-group" data-field="type_stage">
                                    {{ form_label(form.type_stage, 'Type de Stage') }}
                                    {{ form_widget(form.type_stage, {'attr': {'class': 'form-control' ~ (form.type_stage.vars.valid ? '' : ' is-invalid')}}) }}
                                    <div class="form-errors">{{ form_errors(form.type_stage) }}</div>
                                </div>
                                <div class="form-group" data-field="domaine">
                                    {{ form_label(form.domaine, 'Domaine d\'affectation souhaité') }}
                                    {{ form_widget(form.domaine, {'attr': {'class': 'form-control' ~ (form.domaine.vars.valid ? '' : ' is-invalid')}}) }}
                                    <div class="form-errors">{{ form_errors(form.domaine) }}</div>
                                </div>
                            </div>
                            <div class="form-group" data-field="duree">
                                {{ form_label(form.duree, 'Durée du stage souhaitée') }}
                                {{ form_widget(form.duree, {'attr': {'class': 'form-control' ~ (form.duree.vars.valid ? '' : ' is-invalid')}}) }}
                                <div class="form-errors">{{ form_errors(form.duree) }}</div>
                            </div>
                        </div>

                        <!-- Section 4: Documents -->
                        <div class="form-section">
                            <div class="section-title"><span>4</span> Documents (Optionnel si pas de changement)</div>
                            <p class="helper-text" style="margin-bottom: 15px; font-size: 0.85rem; color: #64748b;">
                                <strong>Documents :</strong> PDF uniquement — 2 Mo max.<br>
                                Ne téléchargez des fichiers que si vous souhaitez remplacer les documents existants.
                            </p>
                            <div class="file-upload-grid">
                                <div class="file-upload-item {{ form.cv.vars.valid ? '' : 'has-error' }}" onclick="document.getElementById('{{ form.cv.vars.id }}').click()">
                                    <strong>Curriculum Vitae (CV)</strong><br><span class="file-name">Modifier</span>
                                    {{ form_widget(form.cv, {'attr': {'class': 'file-input', 'onchange': 'updateFileName(this)'}}) }}
                                    <div class="form-errors">{{ form_errors(form.cv) }}</div>
                                </div>
                                <div class="file-upload-item {{ form.lm.vars.valid ? '' : 'has-error' }}" onclick="document.getElementById('{{ form.lm.vars.id }}').click()">
                                    <strong>Lettre de Motivation</strong><br><span class="file-name">Modifier</span>
                                    {{ form_widget(form.lm, {'attr': {'class': 'file-input', 'onchange': 'updateFileName(this)'}}) }}
                                    <div class="form-errors">{{ form_errors(form.lm) }}</div>
                                </div>
                                <div class="file-upload-item {{ form.id_card.vars.valid ? '' : 'has-error' }}" onclick="document.getElementById('{{ form.id_card.vars.id }}').click()">
                                    <strong>Pièce d'identité</strong><br><span class="file-name">Modifier</span>
                                    {{ form_widget(form.id_card, {'attr': {'class': 'file-input', 'onchange': 'updateFileName(this)'}}) }}
                                    <div class="form-errors">{{ form_errors(form.id_card) }}</div>
                                </div>
                                <div class="file-upload-item {{ form.photo.vars.valid ? '' : 'has-error' }}" onclick="document.getElementById('{{ form.photo.vars.id }}').click()">
                                    <strong>Photo d'identité</strong><br><span class="file-name">Modifier</span>
                                    {{ form_widget(form.photo, {'attr': {'class': 'file-input', 'onchange': 'updateFileName(this)'}}) }}
                                    <div class="form-errors">{{ form_errors(form.photo) }}</div>
                                </div>
                                <div class="file-upload-item {{ form.recommandation.vars.valid ? '' : 'has-error' }}" id="recommandation-block" style="display: none;" onclick="document.getElementById('{{ form.recommandation.vars.id }}').click()">
                                    <strong>Lettre de recommandation</strong><br><span class="file-name">Modifier</span>
                                    {{ form_widget(form.recommandation, {'attr': {'class': 'file-input', 'onchange': 'updateFileName(this)'}}) }}
                                    <div class="form-errors">{{ form_errors(form.recommandation) }}</div>
                                </div>
                            </div>
                        </div>

                        <button type="submit" class="btn-submit" id="submitBtn">
                            <span class="btn-content" id="btnContent">
                                <span class="spinner-loader" id="btnSpinner"></span>
                                <span id="btnText">Enregistrer les modifications</span>
                            </span>
                        </button>
                        
                        <a href="{{ path('app_suivi') }}" class="btn-cancel">Annuler</a>

                        <div class="hp-field">
                            {{ form_widget(form.fax_number) }}
                        </div>
                    {{ form_end(form) }}
                </div>
            </div>
        </section>
	</main>

	<footer>
		<div class="container">
			<p class="footer-text">Cour Suprême de la République du Bénin</p>
			<p class="footer-text">&copy; 2026 Tous droits réservés.</p>
		</div>
	</footer>

    <script>
        function updateFileName(input) {
            const fileName = input.files[0] ? input.files[0].name : 'Modifier';
            input.parentElement.querySelector('.file-name').textContent = fileName;
            input.parentElement.style.borderColor = 'var(--primary-green)';
            input.parentElement.style.backgroundColor = '#f0f7f4';
            input.parentElement.classList.remove('has-error');
            const errorDiv = input.parentElement.querySelector('.form-errors');
            if (errorDiv) errorDiv.innerHTML = '';
        }

        const typeStageSelect = document.getElementById('{{ form.type_stage.vars.id }}');
        const recommandationBlock = document.getElementById('recommandation-block');
        
        if (typeStageSelect) {
            typeStageSelect.addEventListener('change', function() {
                if (this.value === 'academique') {
                    recommandationBlock.style.display = 'block';
                } else {
                    recommandationBlock.style.display = 'none';
                }
            });
            if (typeStageSelect.value === 'academique') {
                recommandationBlock.style.display = 'block';
            }
        }

        // ✅ CORRECTION : Soumission AJAX pour le formulaire de modification
        const modifierForm = document.getElementById('modifierForm');
        const submitBtn = document.getElementById('submitBtn');
        const btnSpinner = document.getElementById('btnSpinner');
        const btnText = document.getElementById('btnText');

        if (modifierForm) {
            modifierForm.addEventListener('submit', function(e) {
                e.preventDefault();

                // Reset visuel
                document.querySelectorAll('.has-error').forEach(el => el.classList.remove('has-error'));
                document.querySelectorAll('.is-invalid').forEach(el => el.classList.remove('is-invalid'));
                document.querySelectorAll('.form-errors').forEach(el => el.innerHTML = '');

                // État de chargement
                submitBtn.disabled = true;
                btnSpinner.style.display = 'inline-block';
                btnText.innerText = 'Enregistrement en cours...';

                const formData = new FormData(modifierForm);

                fetch("{{ path('app_modifier_candidature') }}", {
                    method: 'POST',
                    body: formData,
                    headers: {
                        'X-Requested-With': 'XMLHttpRequest'
                    }
                })
                .then(response => {
                    // ✅ CORRECTION : Vérifier si la réponse est une redirection (succès)
                    if (response.redirected) {
                        window.location.href = response.url;
                        return;
                    }
                    return response.text();
                })
                .then(html => {
                    if (!html) return;
                    
                    // ✅ CORRECTION : Si le serveur renvoie du HTML (erreurs de validation),
                    // on remplace le contenu de la page pour afficher les erreurs
                    if (html.includes('is-invalid') || html.includes('has-error')) {
                        document.open();
                        document.write(html);
                        document.close();
                    }
                })
                .catch(error => {
                    console.error('Error:', error);
                    submitBtn.disabled = false;
                    btnSpinner.style.display = 'none';
                    btnText.innerText = 'Enregistrer les modifications';
                });
            });
        }

        window.addEventListener('DOMContentLoaded', (event) => {
            const firstError = document.querySelector('.has-error, .is-invalid, .global-error-alert');
            if (firstError) {
                firstError.scrollIntoView({ behavior: 'smooth', block: 'center' });
            }
        });
    </script>
{% endblock %}