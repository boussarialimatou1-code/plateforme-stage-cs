{% extends 'base.html.twig' %}

{% block title %}Portail Officiel du Recrutement des Stagiaires - Cour Suprême du Bénin{% endblock %}

{% block stylesheets %}
	<link rel="stylesheet" href="{{ asset('css/style.css') }}">
{% endblock %}

{% block body %}
	<header>
		<div class="container">
			<div class="header-top" style="justify-content: center;">
				<div class="logo-section">
					<img src="{{ asset('images/logo_cour_supreme.jpeg') }}" alt="Logo Bénin">
				</div>
			</div>
		</div>
	</header>

	<main>
		<section class="hero">
			<div class="container">
				<div class="hero-flex">
					<div class="hero-content">
						<h2>Portail Officiel du
							<span>Recrutement des Stagiaires</span>
						</h2>
						<p class="hero-description">
							La Cour Suprême de la République du Bénin offre l'opportunité aux étudiants méritants de se former au cœur de la plus haute juridiction de l'État. Remplissez le formulaire ci-dessous pour postuler.
						</p>
						<div class="hero-buttons">
    						<a href="{{ path('app_postuler') }}" class="btn-main">
       							Postuler maintenant
       							<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          							<line x1="5" y1="12" x2="19" y2="12"></line>
           							<polyline points="12 5 19 12 12 19"></polyline>
       							</svg>
   							</a>
   							<a href="{{ path('app_verification') }}" class="btn-outline">Suivre ma candidature</a>
						</div>
					</div>
					<div class="hero-image">
						<img src="{{ asset('images/building.png') }}" alt="Siège de la Cour Suprême">
					</div>
				</div>
			</div>
		</section>

		<section class="engagement">
			<div class="container">
				<h3>Notre Engagement</h3>
				<div class="features-grid">
					<div class="feature-item">
						<div class="icon-box icon-transparence">
							<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
								<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
							</svg>
						</div>
						<h4>Transparence</h4>
						<p>Un processus de sélection rigoureux et équitable.</p>
					</div>
					<div class="feature-item">
						<div class="icon-box icon-excellence">
							<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
								<circle cx="12" cy="8" r="7"></circle>
								<polyline points="8.21 13.89 7 23 12 20 17 23 15.79 13.88"></polyline>
							</svg>
						</div>
						<h4>Excellence</h4>
						<p>Évoluer au contact des plus hauts magistrats.</p>
					</div>
					<div class="feature-item">
						<div class="icon-box icon-apprentissage">
							<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
								<path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"></path>
								<path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"></path>
							</svg>
						</div>
						<h4>Apprentissage</h4>
						<p>Immersion totale dans la pratique du droit.</p>
					</div>
				</div>
			</div>
		</section>
	</main>

	<footer>
		<div class="container">
			<img src="{{ asset('images/logo_cour_supreme.jpeg') }}" alt="Logo Bénin" class="footer-logo">
			<p class="footer-text">Cour Suprême de la République du Bénin</p>
			<p class="footer-text">&copy; 2026 Tous droits réservés.</p>
		</div>
	</footer>
{% endblock %}