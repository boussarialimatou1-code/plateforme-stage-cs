{% extends 'base.html.twig' %}

{% block title %}Récupération du Code - Cour Suprême du Bénin{% endblock %}

{% block stylesheets %}
	<link rel="stylesheet" href="{{ asset('css/styles.css') }}">
	<!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Google Fonts: Montserrat -->
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600;700&display=swap" rel="stylesheet">
{% endblock %}

{% block body %}
    <div class="container-fluid p-0">
        <div class="row g-0 auth-container">
            <!-- Left Section (Desktop only) -->
            <div class="col-lg-6 left-section d-none d-lg-block">
            </div>

            <!-- Right Section -->
            <div class="col-lg-6 right-section bg-white">
                <div class="auth-form-wrapper py-4">

                    <!-- National Colors Strip -->
                    <div class="national-strip-auth">
                        <div style="background-color: #008859;"></div>
                        <div style="background-color: #FFE11B;"></div>
                        <div style="background-color: #D90E15;"></div>
                    </div>

                    <!-- Header -->
                    <div class="mb-5">
                        <h2 class="fw-bold text-dark mb-2">Inscription / Récupération</h2>
                        <p class="text-muted">Obtenez votre code d'accès pour postuler ou suivre votre dossier.</p>
                    </div>

                    <form action="{{ path('app_forgot_code') }}" method="POST">
                        <div class="mb-4">
                            <label for="email" class="form-label small fw-semibold text-secondary">Adresse Email</label>
                            <input type="email" class="form-control" id="email" name="email" placeholder="votre@email.com" required>
                        </div>

                        <div class="mb-4 form-check">
                            <input type="checkbox" class="form-check-input" id="reset" name="reset" value="1">
                            <label class="form-check-label small text-muted" for="reset">Je souhaite générer un <strong>nouveau code</strong> (l'ancien sera annulé)</label>
                        </div>

                        <button type="submit" class="btn btn-primary w-100 btn-auth mb-4 shadow-sm">Recevoir mon code</button>
                    </form>

                    <div class="text-center">
                        <p class="small text-muted mb-0">Vous vous souvenez de votre code ? 
                            <a href="{{ path('app_verification') }}" class="text-secondary fw-bold text-decoration-none">Retour à la vérification</a>
                        </p>
                        <div class="mt-4">
                            <a href="{{ path('app_home') }}" class="text-muted small text-decoration-none">Retour à l'accueil</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
