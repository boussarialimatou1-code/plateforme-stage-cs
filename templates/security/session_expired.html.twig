{% extends 'base.html.twig' %}

{% block title %}Session Expirée - Cour Suprême{% endblock %}

{% block body %}
<div class="container d-flex align-items-center justify-content-center" style="min-height: 100vh; background-color: #f8f9fa;">
    <div class="card shadow-lg border-0 text-center p-5" style="max-width: 500px; border-radius: 20px;">
        <div class="mb-4">
            <div class="bg-light rounded-circle d-inline-flex align-items-center justify-content-center" style="width: 100px; height: 100px; background: #fff3cd !important;">
                <i class="fas fa-hourglass-end fa-3x text-warning"></i>
            </div>
        </div>
        <h2 class="fw-bold text-dark mb-3" style="letter-spacing: -1px;">Session Expirée</h2>
        <p class="text-muted mb-4" style="font-size: 1.1rem;">Par mesure de sécurité, votre session a été interrompue. Pour continuer, veuillez vous reconnecter à votre espace.</p>
        
        <div class="d-grid gap-3">
            <a href="{{ path('app_home') }}" class="btn btn-primary btn-lg rounded-pill px-4 py-3 shadow-sm" style="background: #001a33; border: none; font-weight: 600;">
                <i class="fas fa-sign-in-alt mr-2"></i> Retour à la connexion
            </a>
            <a href="{{ path('app_home') }}" class="btn btn-light btn-lg rounded-pill px-4 py-3 border" style="font-weight: 500;">
                Accueil du site
            </a>
        </div>
        
        <div class="mt-4 pt-3 border-top">
            <small class="text-muted">Cour Suprême - Gestion des Stages</small>
        </div>
    </div>
</div>

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
<style>
    body { background-color: #f8f9fa; }
    .btn-primary:hover { background: #002b4d !important; transform: translateY(-2px); transition: all 0.3s; }
</style>
{% endblock %}
