{% extends 'base.html.twig' %}

{% block title %}Mot de passe oublié - Cour Suprême{% endblock %}

{% block stylesheets %}
<style>
    body {
        background: linear-gradient(135deg, #001a33 0%, #002244 100%);
        height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0;
        font-family: 'Source Sans Pro', sans-serif;
    }
    .login-container { width: 100%; max-width: 450px; padding: 15px; }
    .card { border: none; border-radius: 12px; box-shadow: 0 15px 35px rgba(0,0,0,0.3); overflow: hidden; background-color: rgba(255, 255, 255, 0.98); }
    .card-header-supreme { background-color: #002244; color: white; text-align: center; padding: 30px 20px; border-bottom: 3px solid #c5a059; }
    .logo-supreme { max-width: 80px; margin-bottom: 15px; }
    .institution-name { font-size: 1.2rem; font-weight: 700; letter-spacing: 2px; margin: 0; text-transform: uppercase; }
    .card-body { padding: 40px; text-align: center; }
    .form-group label { font-weight: 600; color: #002244; font-size: 0.85rem; text-transform: uppercase; margin-bottom: 12px; display: block; text-align: left; }
    .form-control { height: 50px; border-radius: 6px; border: 1px solid #dee2e6; padding: 10px 15px; width: 100%; }
    .form-control:focus { border-color: #c5a059; box-shadow: 0 0 0 0.2rem rgba(197, 160, 89, 0.25); }
    .btn-supreme { background-color: #002244; color: white; border: none; height: 50px; font-weight: 700; text-transform: uppercase; width: 100%; border-radius: 6px; transition: all 0.3s; }
    .btn-supreme:hover { background-color: #001a33; color: #c5a059; }
</style>
{% endblock %}

{% block body %}
<div class="login-container">
    <div class="card">
        <div class="card-header-supreme">
            <img src="{{ asset('images/logo_cour_supreme.jpeg') }}" alt="Logo" class="logo-supreme">
            <h1 class="institution-name">Récupération</h1>
        </div>
        <div class="card-body">
            {% for label, messages in app.flashes %}
                {% for message in messages %}
                    <div class="alert alert-{{ label == 'error' ? 'danger' : 'success' }} mb-4" style="font-size: 0.85rem; padding: 10px; border-radius: 6px; text-align: left;">
                        <i class="fas fa-{{ label == 'error' ? 'exclamation-circle' : 'check-circle' }} mr-2"></i>
                        {{ message }}
                    </div>
                {% endfor %}
            {% endfor %}

            <p style="color: #64748b; font-size: 0.9rem; margin-bottom: 25px;">Saisissez votre email pour recevoir un lien de réinitialisation (valable 5 min).</p>
            <form method="post">
                <div class="form-group mb-4">
                    <label for="email">Votre Email Professionnel</label>
                    <input type="email" name="email" id="email" class="form-control" placeholder="exemple@coursupreme.bj" required autofocus>
                </div>
                <button class="btn btn-supreme" type="submit">Envoyer le lien</button>
            </form>
            <div class="mt-4">
                <a href="{{ path('app_login') }}" style="color: #64748b; font-size: 0.85rem; text-decoration: none;">Retour à la connexion</a>
            </div>
        </div>
    </div>
</div>
{% endblock %}

