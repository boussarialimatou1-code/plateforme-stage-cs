{% extends 'base.html.twig' %}

{% block title %}Définir un nouveau mot de passe - Cour Suprême{% endblock %}

{% block stylesheets %}
<style>
    body {
        background: linear-gradient(135deg, #001a33 0%, #002244 100%);
        height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0;
        font-family: 'Source Sans Pro', sans-serif;
    }
    .login-container { width: 100%; max-width: 450px; padding: 15px; }
    .card { border: none; border-radius: 12px; box-shadow: 0 15px 35px rgba(0,0,0,0.3); overflow: hidden; background-color: rgba(255, 255, 255, 0.98); }
    .card-header-supreme { background-color: #16a34a; color: white; text-align: center; padding: 30px 20px; border-bottom: 3px solid #bbf7d0; }
    .institution-name { font-size: 1.2rem; font-weight: 700; letter-spacing: 2px; margin: 0; text-transform: uppercase; }
    .card-body { padding: 40px; text-align: center; }
    .form-group label { font-weight: 600; color: #002244; font-size: 0.85rem; text-transform: uppercase; margin-bottom: 12px; display: block; text-align: left; }
    .form-control { height: 50px; border-radius: 6px; border: 1px solid #dee2e6; padding: 10px 15px; width: 100%; }
    .form-control:focus { border-color: #16a34a; box-shadow: 0 0 0 0.2rem rgba(22, 163, 74, 0.25); }
    .btn-reset { background-color: #16a34a; color: white; border: none; height: 50px; font-weight: 700; text-transform: uppercase; width: 100%; border-radius: 6px; transition: all 0.3s; }
    .btn-reset:hover { background-color: #15803d; }
</style>
{% endblock %}

{% block body %}
<div class="login-container">
    <div class="card">
        <div class="card-header-supreme">
            <h1 class="institution-name">Nouveau Mot de Passe</h1>
        </div>
        <div class="card-body">
            <p style="color: #64748b; font-size: 0.9rem; margin-bottom: 25px;">Choisissez un mot de passe sécurisé pour votre accès agent.</p>
            <form method="post">
                <div class="form-group mb-4">
                    <label for="password">Nouveau mot de passe</label>
                    <input type="password" name="password" id="password" class="form-control" required autofocus placeholder="••••••••">
                </div>
                <div class="form-group mb-4">
                    <label for="confirm_password">Confirmez le mot de passe</label>
                    <input type="password" name="confirm_password" id="confirm_password" class="form-control" required placeholder="••••••••">
                </div>
                <button class="btn btn-reset" type="submit">Valider le changement</button>
            </form>
        </div>
    </div>
</div>
{% endblock %}
