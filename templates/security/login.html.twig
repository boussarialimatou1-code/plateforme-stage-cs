{% extends 'base.html.twig' %}

{% block title %}Connexion Évaluateur - Cour Suprême{% endblock %}

{% block stylesheets %}
<style>
    body {
        background: linear-gradient(135deg, #001a33 0%, #002244 100%);
        height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0;
        font-family: 'Source Sans Pro', sans-serif;
    }

    .login-container {
        width: 100%;
        max-width: 450px;
        padding: 15px;
    }

    .card {
        border: none;
        border-radius: 12px;
        box-shadow: 0 15px 35px rgba(0,0,0,0.3);
        overflow: hidden;
        background-color: rgba(255, 255, 255, 0.98);
    }

    .card-header-supreme {
        background-color: #002244;
        color: white;
        text-align: center;
        padding: 30px 20px;
        border-bottom: 3px solid #c5a059; /* Ligne Or */
    }

    .logo-supreme {
        max-width: 100px;
        margin-bottom: 15px;
        filter: drop-shadow(0 2px 4px rgba(0,0,0,0.2));
    }

    .institution-name {
        font-size: 1.2rem;
        font-weight: 700;
        letter-spacing: 2px;
        margin: 0;
        text-transform: uppercase;
    }

    .platform-name {
        font-size: 0.9rem;
        color: #c5a059;
        margin-top: 5px;
        font-weight: 400;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    .card-body {
        padding: 40px;
        text-align: center;
    }

    .form-group {
        display: flex;
        flex-direction: column;
        align-items: center;
        margin-bottom: 25px;
    }

    .form-group label {
        font-weight: 600;
        color: #002244;
        font-size: 0.85rem;
        text-transform: uppercase;
        margin-bottom: 12px;
    }

    .input-group {
        width: 100%;
        max-width: 350px;
    }

    .form-control {
        height: 50px;
        border-radius: 6px;
        border: 1px solid #dee2e6;
        padding: 10px 15px;
        transition: all 0.3s;
    }

    .form-control:focus {
        border-color: #c5a059;
        box-shadow: 0 0 0 0.2rem rgba(197, 160, 89, 0.25);
    }

    .btn-supreme {
        background-color: #002244;
        color: white;
        border: none;
        height: 50px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1px;
        border-radius: 6px;
        transition: all 0.3s;
        width: 100%;
        max-width: 350px;
        margin: 10px auto;
        display: inline-flex;
        align-items: center;
        justify-content: center;
    }

    .btn-supreme:hover {
        background-color: #001a33;
        color: #c5a059;
        box-shadow: 0 5px 15px rgba(0,0,0,0.2);
    }

    .alert {
        border-radius: 6px;
        font-size: 0.9rem;
        margin-bottom: 25px;
    }

    .footer-login {
        text-align: center;
        margin-top: 25px;
        color: rgba(255,255,255,0.6);
        font-size: 0.8rem;
    }
    
    .input-group-text {
        background-color: transparent;
        border-right: none;
        color: #adb5bd;
    }
    
    .form-control-with-icon {
        border-left: none;
    }
</style>
{% endblock %}

{% block body %}
<div class="login-container">
    <div class="card">
        <div class="card-header-supreme">
            <img src="{{ asset('images/logo_cour_supreme.jpeg') }}" alt="Logo Cour Suprême" class="logo-supreme">
            <h1 class="institution-name">Cour Suprême</h1>
            <div class="platform-name">Espace de Gestion des Stages</div>
        </div>

        <div class="card-body">
            <form method="post">
                {% if error %}
                    <div class="alert alert-danger shadow-sm border-0">
                        <i class="fas fa-exclamation-circle mr-2"></i> {{ error.messageKey|trans(error.messageData, 'security') }}
                    </div>
                {% endif %}

                <div class="form-group mb-4">
                    <label for="inputUsername">Adresse Email</label>
                    <div class="input-group">
                        <div class="input-group-prepend">
                            <span class="input-group-text"><i class="fas fa-envelope"></i></span>
                        </div>
                        <input type="email" value="{{ last_username }}" name="_username" id="inputUsername" class="form-control form-control-with-icon" autocomplete="email" required autofocus placeholder="exemple@coursupreme.bj">
                    </div>
                </div>

                <div class="form-group mb-4">
                    <label for="inputPassword">Mot de passe</label>
                    <div class="input-group">
                        <div class="input-group-prepend">
                            <span class="input-group-text"><i class="fas fa-lock"></i></span>
                        </div>
                        <input type="password" name="_password" id="inputPassword" class="form-control form-control-with-icon" autocomplete="current-password" required placeholder="••••••••">
                    </div>
                </div>

                <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

                <button class="btn btn-supreme mt-2" type="submit">
                    <i class="fas fa-sign-in-alt mr-2"></i> Se Connecter
                </button>

                <div class="mt-4">
                    <a href="{{ path('app_forgot_password_request') }}" style="color: #64748b; font-size: 0.85rem; text-decoration: none;">
                        <i class="fas fa-key mr-1"></i> Mot de passe oublié ?
                    </a>
                </div>
            </form>
        </div>
    </div>
    
    <div class="footer-login">
        &copy; {{ "now"|date("Y") }} Cour Suprême de la République du Bénin<br>
        <small>Accès strictement réservé au personnel autorisé.</small>
    </div>
</div>
{% endblock %}
