<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <title>{% block title %}Welcome!{% endblock %}</title>
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>⚫️</text><text y=%221.3em%22 x=%220.2em%22 font-size=%2276%22 fill=%22%23fff%22>sf</text></svg>">
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
        {% block stylesheets %}
        {% endblock %}

        <style>
            /* Style pour les messages Flash (Success/Error) */
            .flash-container {
                position: fixed;
                top: 20px;
                left: 50%;
                transform: translateX(-50%);
                z-index: 9999;
                width: 100%;
                max-width: 600px;
                padding: 0 20px;
            }

            .alert-custom {
                border: none;
                border-radius: 12px;
                padding: 16px 24px;
                box-shadow: 0 10px 30px rgba(0,0,0,0.1);
                display: flex;
                align-items: center;
                gap: 15px;
                margin-bottom: 10px;
                animation: slideDown 0.4s ease-out;
            }

            .alert-custom-success {
                background-color: #f0fdf4;
                color: #16a34a;
                border-left: 5px solid #16a34a;
            }

            .alert-custom-error {
                background-color: #fef2f2;
                color: #dc2626;
                border-left: 5px solid #dc2626;
            }

            .alert-custom-info {
                background-color: #eff6ff;
                color: #1d4ed8;
                border-left: 5px solid #1d4ed8;
            }

            .alert-icon {
                flex-shrink: 0;
            }

            @keyframes slideDown {
                from { opacity: 0; transform: translateY(-20px); }
                to { opacity: 1; transform: translateY(0); }
            }

            .btn-close-custom {
                background: transparent;
                border: none;
                margin-left: auto;
                color: currentColor;
                opacity: 0.5;
                cursor: pointer;
            }
            .btn-close-custom:hover { opacity: 1; }
        </style>

        {% block javascripts %}
        {% endblock %}
    </head>
    <body data-theme="light">
        
        <!-- Container des notifications -->
        <div class="flash-container">
            {# Affichage du Code d'Accès Éphémère (Design Ultra-Compact) #}
            {% for message in app.flashes('access_code') %}
                <div class="access-code-bar">
                    <div class="bar-content">
                        <div class="info-part">
                            <div class="security-dot"></div>
                            <span class="bar-title">CODE GÉNÉRÉ :</span>
                            <span class="bar-desc">Notez ce code pour votre suivi</span>
                        </div>
                        <div class="code-part">
                            <span class="code-text" id="generatedCode">{{ message }}</span>
                            <button class="btn-copy-slim" onclick="copyCode()" title="Copier">
                                <svg id="copyIcon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>
                                <svg id="checkIcon" class="hidden" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#00ff80" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
                            </button>
                        </div>
                    </div>
                </div>

                <style>
                    .access-code-bar {
                        background: #1a2b4b;
                        border-radius: 8px;
                        padding: 8px 15px;
                        margin-bottom: 10px;
                        color: white;
                        box-shadow: 0 4px 15px rgba(0,0,0,0.1);
                        border: 1px solid rgba(255,255,255,0.1);
                        width: 100%;
                        position: relative;
                        overflow: hidden;
                    }
                    .bar-content { display: flex; justify-content: space-between; align-items: center; gap: 15px; }
                    .info-part { display: flex; align-items: center; gap: 10px; }
                    .security-dot { width: 8px; height: 8px; background: #00ff80; border-radius: 50%; box-shadow: 0 0 10px #00ff80; animation: pulse-dot 2s infinite; }
                    .bar-title { font-size: 0.75rem; font-weight: 800; letter-spacing: 0.5px; color: #00ff80; }
                    .bar-desc { font-size: 0.75rem; color: #94a3b8; }
                    .code-part { display: flex; align-items: center; gap: 12px; background: rgba(255,255,255,0.05); padding: 4px 10px; border-radius: 6px; }
                    .code-text { font-family: 'JetBrains Mono', monospace; font-size: 1.1rem; font-weight: 800; color: #fff; }
                    .btn-copy-slim { background: transparent; color: #94a3b8; border: none; cursor: pointer; display: flex; align-items: center; }
                    .hidden { display: none; }
                    @keyframes pulse-dot { 0%, 100% { opacity: 1; } 50% { opacity: 0.4; } }
                </style>
                <script>
                    function copyCode() {
                        const code = document.getElementById('generatedCode').innerText;
                        navigator.clipboard.writeText(code).then(() => {
                            document.getElementById('copyIcon').classList.add('hidden');
                            document.getElementById('checkIcon').classList.remove('hidden');
                            setTimeout(() => {
                                document.getElementById('copyIcon').classList.remove('hidden');
                                document.getElementById('checkIcon').classList.add('hidden');
                            }, 2000);
                        });
                    }
                </script>
            {% endfor %}

            {# Alertes Classiques Success/Error #}
            {% for label, messages in app.flashes %}
                {% if label != 'access_code' %}
                    {% for message in messages %}
                        <div class="alert-custom alert-custom-{{ label == 'error' ? 'error' : (label == 'info' ? 'info' : 'success') }}" role="alert">
                            <div class="alert-icon">
                                {% if label == 'error' %}
                                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="8" x2="12" y2="12"></line><line x1="12" y1="16" x2="12.01" y2="16"></line></svg>
                                {% elseif label == 'info' %}
                                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="16" x2="12.01" y2="16"></line><line x1="12" y1="12" x2="12" y2="8"></line></svg>
                                {% else %}
                                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
                                {% endif %}
                            </div>
                            <div class="alert-message">
                                {{ message }}
                            </div>
                            <button type="button" class="btn-close-custom" onclick="this.parentElement.remove()">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
                            </button>
                        </div>
                    {% endfor %}
                {% endif %}
            {% endfor %}
        </div>

        {% block body %}{% endblock %}
        
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    </body>
</html>
