{% extends 'admin_base.html.twig' %}

{% block title %}Statistiques des Dossiers - Cour Suprême{% endblock %}
{% block header_title %}Statistiques des Candidatures{% endblock %}

{% block body %}
<div class="row">
    <!-- Total Dossiers -->
    <div class="col-lg-3 col-6">
        <div class="small-box bg-info">
            <div class="inner">
                <h3>{{ total_dossiers }}</h3>
                <p>Total Candidatures</p>
            </div>
            <div class="icon">
                <i class="fas fa-folder-open"></i>
            </div>
            <a href="{{ path('app_evaluator_evaluations_list') }}" class="small-box-footer">
                Voir tout <i class="fas fa-arrow-circle-right"></i>
            </a>
        </div>
    </div>

    <!-- En Attente -->
    <div class="col-lg-3 col-6">
        <div class="small-box bg-warning">
            <div class="inner">
                <h3>{{ en_attente }}</h3>
                <p>Nouveaux (En Attente)</p>
            </div>
            <div class="icon">
                <i class="fas fa-clock"></i>
            </div>
            <a href="{{ path('app_evaluator_evaluations_list', {statut: 'En attente'}) }}" class="small-box-footer">
                Voir la liste <i class="fas fa-arrow-circle-right"></i>
            </a>
        </div>
    </div>

    <!-- En Évaluation -->
    <div class="col-lg-3 col-6">
        <div class="small-box bg-primary">
            <div class="inner">
                <h3>{{ en_evaluation }}</h3>
                <p>En Évaluation</p>
            </div>
            <div class="icon">
                <i class="fas fa-search"></i>
            </div>
            <a href="{{ path('app_evaluator_evaluations_list', {statut: 'En évaluation'}) }}" class="small-box-footer">
                Voir la liste <i class="fas fa-arrow-circle-right"></i>
            </a>
        </div>
    </div>

    <!-- Mis en Réserve -->
    <div class="col-lg-3 col-6">
        <div class="small-box bg-secondary">
            <div class="inner">
                <h3>{{ mis_en_reserve }}</h3>
                <p>Mis en Réserve</p>
            </div>
            <div class="icon">
                <i class="fas fa-archive"></i>
            </div>
            <a href="{{ path('app_evaluator_evaluations_list', {statut: 'Mis en réserve'}) }}" class="small-box-footer">
                Voir la liste <i class="fas fa-arrow-circle-right"></i>
            </a>
        </div>
    </div>
</div>

<div class="row mt-4">
    <!-- Validés -->
    <div class="col-lg-6 col-12">
        <div class="small-box bg-success">
            <div class="inner">
                <h3>{{ valide }}</h3>
                <p>Stages Validés</p>
            </div>
            <div class="icon">
                <i class="fas fa-check-circle"></i>
            </div>
            <a href="{{ path('app_evaluator_evaluations_list', {statut: 'Validé'}) }}" class="small-box-footer">
                Voir la liste <i class="fas fa-arrow-circle-right"></i>
            </a>
        </div>
    </div>

    <!-- Refusés -->
    <div class="col-lg-6 col-12">
        <div class="small-box bg-danger">
            <div class="inner">
                <h3>{{ refuse }}</h3>
                <p>Candidatures Refusées</p>
            </div>
            <div class="icon">
                <i class="fas fa-times-circle"></i>
            </div>
            <a href="{{ path('app_evaluator_evaluations_list', {statut: 'Rejeté'}) }}" class="small-box-footer">
                Voir la liste <i class="fas fa-arrow-circle-right"></i>
            </a>
        </div>
    </div>
    <!-- Repartion par structure -->
    <div class="col-12 mt-4">
        <h3 class="mb-3"><i class="fas fa-building mr-1"></i> Répartition des Stages Validés par Structure</h3>
    </div>
    {% for dossier in dossier_par_structure %}
        <div class="col-lg-4 col-12">
            <div class="small-box bg-info">
                <div class="inner">
                    <h3>{{ dossier.count }}</h3>
                    <p>{{ dossier.structure }}</p>
                </div>
                <div class="icon">
                    <i class="fas fa-times-circle"></i>
                </div>
                <a href="{{ path('app_evaluator_evaluations_list', {statut: 'Validé' ,structure: dossier.value }) }}" class="small-box-footer">
                    Voir la liste <i class="fas fa-arrow-circle-right"></i>
                </a>
            </div>
        </div>
    {% endfor %}

</div>



<div class="row mt-4">
    <div class="col-12">
        <div class="card">
            <div class="card-header border-0">
                <h3 class="card-title font-weight-bold">
                    <i class="fas fa-graduation-cap mr-1"></i>
                    Stages Actifs (Dernières validations)
                </h3>
            </div>
            <div class="card-body p-0">
                <table class="table table-striped table-valign-middle">
                    <thead>
                        <tr>
                            <th>Candidat</th>
                            <th>Domaine</th>
                            <th>Début</th>
                            <th>Fin</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for stage in stages_actifs %}
                            <tr>
                                <td>
                                    {% if stage.candidat %}
                                        {{ stage.candidat.nom }} {{ stage.candidat.prenom }}
                                    {% else %}
                                        <span class="text-muted font-italic">Inconnu</span>
                                    {% endif %}
                                </td>
                                <td><span class="badge badge-info">{{ stage.domaine }}</span></td>
                                <td>{{ stage.dateDebutStage|date('d/m/Y') }}</td>
                                <td>{{ stage.dateFinStage|date('d/m/Y') }}</td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="4" class="text-center text-muted py-4">Aucun stage actif pour le moment.</td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

{% endblock %}
